# ── Server ────────────────────────────────────────────────────────────
# All user credentials (Groq API key, Gmail address, App Password, name)
# are entered in the app's Settings tab and stored per-user in Firestore.
# Do NOT put personal credentials here.

PORT=3000

# ── Firebase Web Config (public — identifies your Firebase project) ───
# Get these from Firebase Console → Project Settings → Your apps → Web
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
